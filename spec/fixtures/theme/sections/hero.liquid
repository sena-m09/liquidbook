<section class="hero">
  <h1>{{ section.settings.title }}</h1>
  {% if section.settings.show_button -%}
    <button>Shop Now</button>
  {%- endif %}
  {% for block in section.blocks %}
    <img src="{{ block.settings.image_src }}">
  {% endfor %}
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "id": "title", "type": "text", "label": "Title", "default": "Welcome" },
    { "id": "show_button", "type": "checkbox", "label": "Show button", "default": true }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [{ "id": "image_src", "type": "text", "label": "Image", "default": "https://placehold.co/800x400" }]
    }
  ]
}
{% endschema %}
