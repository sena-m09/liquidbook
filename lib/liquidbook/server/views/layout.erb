<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Liquidbook</title>
  <%= head_tags %>
  <style>
    :root {
      --lp-bg: #f5f5f5;
      --lp-surface: #fff;
      --lp-text: #1a1a1a;
      --lp-text-sub: #666;
      --lp-accent: #5c6ac4;
      --lp-border: #e0e0e0;
      --lp-radius: 8px;
    }
    .lp-topbar {
      background: var(--lp-surface);
      border-bottom: 1px solid var(--lp-border);
      padding: 12px 24px;
      display: flex;
      align-items: center;
      gap: 16px;
      position: sticky;
      top: 0;
      z-index: 10000;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }
    .lp-topbar h1 {
      font-size: 16px;
      font-weight: 600;
      color: var(--lp-accent);
      margin: 0;
    }
    .lp-topbar nav a {
      color: var(--lp-text-sub);
      text-decoration: none;
      font-size: 14px;
    }
    .lp-topbar nav a:hover { color: var(--lp-accent); }
    .lp-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 24px;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }
  </style>
</head>
<body>
  <div class="lp-topbar">
    <h1>Liquidbook</h1>
    <nav><a href="/">Home</a></nav>
  </div>
  <div class="lp-container">
    <%= yield %>
  </div>
</body>
</html>
